{
  email {$ACME_EMAIL}
  admin off
}

bkg.eysho.info {
  encode zstd gzip

  basic_auth {
    {$NOVA_WEB_USER} {$NOVA_WEB_PASSWORD_HASH}
  }

  @remote_browser path /remote-browser/*
  handle @remote_browser {
    uri strip_prefix /remote-browser
    reverse_proxy remote-browser:6080
  }

  handle {
    reverse_proxy nova:3000
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    X-Content-Type-Options "nosniff"
    Referrer-Policy "same-origin"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
  }

  log {
    output stdout
    format console
  }
}
