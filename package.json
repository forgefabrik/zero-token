{
  "name": "zero-token",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Inoffizielles, experimentelles lokales Werkzeug – Kein OpenAI-Produkt. Stellt ChatGPT-Plus-Chatmodelle über CLI, Web-Konsole und OpenAI-kompatibles HTTP-Gateway bereit.",
  "license": "MIT",
  "bin": {
    "zt": "./dist/index.js"
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/zero-token/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "ui:build": "cd web-console && npx vite build",
    "ui:dev": "cd web-console && npx vite dev"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "hono": "^4.12.0",
    "pino": "^10.3.0",
    "playwright": "^1.61.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "pino-pretty": "^13.1.0",
    "svelte": "^5.56.0",
    "typescript": "^5.8.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.0"
  }
}
